# Copy this file to: android/keystore.properties
# NEVER commit android/keystore.properties or *.jks to git.
#
# storeFile path is resolved relative to android/app/ (same folder as app/build.gradle).
# Put the Play upload keystore there:
#   android/app/@abhi0000__My_Building.jks
#
# Credentials come from EAS (expo credentials) or Google Play App Signing.
# Play Console → Setup → App signing shows the upload certificate SHA-1/SHA-256
# that must match the key used to sign each AAB.

storeFile=@abhi0000__My_Building.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
