# Copy this file to: ../android/keystore.properties (same folder as android/build.gradle).
# NEVER commit android/keystore.properties or *.jks to git.
#
# storeFile path is resolved relative to android/app/, so put your Play keystore
# beside android/app/build.gradle OR use ../path/to-keystore.jks from there.

storeFile=my-release-key.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=YOUR_ALIAS
keyPassword=YOUR_KEY_PASSWORD
